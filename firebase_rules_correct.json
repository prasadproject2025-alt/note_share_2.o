{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || auth.isAnonymous == true)",
        ".write": "auth != null && (auth.uid == $uid || auth.isAnonymous == true)",
        "coins": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "notes": {
      ".read": true,
      ".indexOn": ["seller_id", "course_code", "slot", "status"],
      "$noteId": {
        ".write": "auth != null && (root.child('notes').child($noteId).child('seller_id').val() == auth.uid || auth.isAnonymous == true || !root.child('notes').child($noteId).exists())"
      }
    },
    "shared_notes": {
      ".read": true,
      ".indexOn": ["sharer_id", "batch"],
      "$noteId": {
        ".write": "auth != null && (root.child('shared_notes').child($noteId).child('sharer_id').val() == auth.uid || auth.isAnonymous == true || !root.child('shared_notes').child($noteId).exists())"
      }
    },
    "rental_notes": {
      ".read": true,
      ".indexOn": ["renter_id", "course_code", "slot"],
      "$noteId": {
        ".write": "auth != null && (root.child('rental_notes').child($noteId).child('renter_id').val() == auth.uid || auth.isAnonymous == true || !root.child('rental_notes').child($noteId).exists())"
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['user1_id', 'user2_id']) || newData.hasChildren(['buyer_id', 'seller_id'])"
      }
    },
    "messages": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["chat_id", "timestamp"],
      ".validate": "newData.hasChildren(['chat_id', 'sender_id', 'text', 'timestamp'])"
    },
    "typing": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "test": {
      ".read": true,
      ".write": true
    },
    "debug_test": {
      ".read": true,
      ".write": true
    }
  }
}