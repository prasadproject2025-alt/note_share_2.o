# NoteShare Environment Configuration
# Copy this file to .env and update with your actual credentials

# ============================================
# Firebase Configuration
# ============================================
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID
FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# ============================================
# Google OAuth Configuration
# ============================================
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/note_share/auth/google_callback.php

# ============================================
# Razorpay Payment Gateway
# ============================================
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_MODE=test  # Change to 'live' for production

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@noteshare.com
SMTP_FROM_NAME=NoteShare

# ============================================
# Gmail API (fallback / preferred when SMTP blocked)
# ============================================
# OAuth client credentials and refresh token for Gmail API (scope: https://www.googleapis.com/auth/gmail.send)
GMAIL_CLIENT_ID=448092108367-g1q3qjf5fbj9lhdebqp1b38dv5rbd4uf.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=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
GMAIL_REFRESH_TOKEN=your-obtained-refresh-token
# FROM email used when sending via Gmail API (optional, falls back to SMTP_FROM_EMAIL)
FROM_EMAIL=you@yourdomain.com

# ============================================
# Application Configuration
# ============================================
APP_NAME=NoteShare
APP_VERSION=1.0.0
APP_ENV=development  # development, staging, production
APP_DEBUG=true  # Set to false in production
APP_URL=http://localhost:8000

# ============================================
# Database Configuration
# ============================================
DB_TYPE=firebase  # firebase, mysql (for future use)
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ============================================
# Session Configuration
# ============================================
SESSION_TIMEOUT=1800  # 30 minutes in seconds
SESSION_SECURE=false  # Set to true in production with HTTPS
SESSION_HTTP_ONLY=true

# ============================================
# Security Configuration
# ============================================
ENCRYPTION_KEY=your-secret-encryption-key-min-32-characters
CSRF_TOKEN_LENGTH=32

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif
UPLOAD_PATH=uploads/
TEMP_PATH=temp/

# ============================================
# Coin System Configuration
# ============================================
COIN_EXCHANGE_RATE=0.10  # ₹0.10 per coin
MIN_COINS_TO_MESSAGE=1
COIN_PACKAGES=100:10,500:45,1000:80,5000:350

# ============================================
# Email Verification (Optional)
# ============================================
ENABLE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TIMEOUT=3600  # 1 hour

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=10
RATE_LIMIT_TIMEOUT=3600  # 1 hour

# ============================================
# Logging Configuration
# ============================================
LOG_CHANNEL=single  # single, daily, syslog
LOG_LEVEL=debug  # debug, info, notice, warning, error, critical, alert, emergency
LOG_PATH=logs/

# ============================================
# AWS Configuration (Optional - for S3)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=noteshare-uploads

# ============================================
# Sentry Configuration (Optional - for error tracking)
# ============================================
SENTRY_DSN=

# ============================================
# Redis Configuration (Optional - for caching)
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_EXPIRY=3600

# ============================================
# API Rate Limiting
# ============================================
API_RATE_LIMIT=100  # requests per minute
API_BURST_LIMIT=10  # burst requests

# ============================================
# Development Tools (Set to false in production)
# ============================================
ENABLE_PROFILER=false
ENABLE_DEBUGBAR=false
ENABLE_QUERY_LOG=false

# ============================================
# Notification Settings
# ============================================
SEND_WELCOME_EMAIL=true
SEND_ORDER_CONFIRMATION=true
SEND_PAYMENT_NOTIFICATION=true

# ============================================
# Support & Contact
# ============================================
SUPPORT_EMAIL=support@noteshare.com
SUPPORT_PHONE=+91-XXXXXXXXXX
CONTACT_EMAIL=contact@noteshare.com
