{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || auth == null",
        ".write": "$uid === auth.uid || auth == null",
        "coins": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "notes": {
      ".read": true,
      ".indexOn": ["seller_id", "course_code", "slot", "status"],
      "$noteId": {
        ".write": "root.child('notes').child($noteId).child('seller_id').val() === auth.uid || auth == null || !root.child('notes').child($noteId).exists()"
      }
    },
    "shared_notes": {
      ".read": true,
      ".indexOn": ["sharer_id", "batch"],
      "$noteId": {
        ".write": "root.child('shared_notes').child($noteId).child('sharer_id').val() === auth.uid || auth == null || !root.child('shared_notes').child($noteId).exists()"
      }
    },
    "rental_notes": {
      ".read": true,
      ".indexOn": ["renter_id", "course_code", "slot"],
      "$noteId": {
        ".write": "root.child('rental_notes').child($noteId).child('renter_id').val() === auth.uid || auth == null || !root.child('rental_notes').child($noteId).exists()"
      }
    },
    "chats": {
      "$chatId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['buyer_id', 'seller_id']) || newData.hasChildren(['user1_id', 'user2_id'])"
      }
    },
    "messages": {
      ".read": true,
      ".write": true,
      ".indexOn": ["chat_id", "timestamp"],
      ".validate": "newData.hasChildren(['chat_id', 'sender_id', 'message', 'timestamp'])"
    },
    "typing": {
      "$chatId": {
        ".read": true,
        ".write": true
      }
    }
  }
}